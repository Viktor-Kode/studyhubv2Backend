# Termii — WhatsApp + SMS notifications (replaces YCloud)
# Get keys at https://accounts.termii.com
TERMII_API_KEY=your_termii_api_key
TERMII_SENDER_ID=StudyHelp

# Removed (YCloud):
# YCLOUD_API_KEY
# YCLOUD_WHATSAPP_NUMBER

# Twilio WhatsApp (reminders / timetable)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# TWILIO_TIMETABLE_CONTENT_SID=

# Reminder times in the app are interpreted as this offset (default Nigeria WAT = UTC+1).
# Only change if your users are in a different single zone.
# REMINDER_TZ_OFFSET=+01:00
