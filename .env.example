# SERVER
PORT=5000
NODE_ENV=development

# DATABASE
# Render usually provides MONGODB_URI or MONGO_URI
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/dbname

# AUTHENTICATION
JWT_SECRET=your_super_secret_jwt_key
JWT_EXPIRES_IN=90d

# THIRD PARTY SERVICES
# ALOC Questions API (CBT)
ALOC_ACCESS_TOKEN=ALOC-your-token-here

# Twilio (WhatsApp/SMS)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=your_token
TWILIO_PHONE_NUMBER=whatsapp:+1234567890

# AI Models
DEEPSEEK_API_KEY=sk-...
HF_TOKEN=hf_...

# FIREBASE
FIREBASE_PROJECT_ID=...
